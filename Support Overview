<!DOCTYPE html>
<html>
<head>
<style>
*{box-sizing:border-box;margin:0;padding:0;}
html,body{height:auto;overflow:visible;}
body{font-family:Arial,sans-serif;background:transparent;padding:8px;}
.card{background:white;border:1px solid #D3D1C7;border-radius:10px;overflow:hidden;width:100%;}
.card-top{background:linear-gradient(135deg,#1a5f7a,#2980a0);padding:16px 18px;}
.card-top h3{font-size:20px;font-weight:700;color:white;margin-bottom:4px;}
.card-top p{font-size:14px;color:#b8dff0;}
.inner{background:#F3F2F1;border-radius:8px;padding:14px;margin:14px;}
.row{display:flex;gap:12px;padding:14px 0;border-bottom:1px solid #D3D1C7;align-items:flex-start;}
.row:last-child{border-bottom:none;padding-bottom:0;}
.dot{width:38px;height:38px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0;}
.rtext h4{font-size:16px;font-weight:700;color:#2C2C2A;margin-bottom:4px;}
.rtext p{font-size:14px;color:#5F5E5A;line-height:1.5;}
.rtext .how{font-size:14px;color:#1a5f7a;font-weight:700;margin-top:4px;}
</style>
</head>
<body>

<div class="card">
  <div class="card-top">
    <h3>Support overview</h3>
    <p>A quick guide to supporting colleagues</p>
  </div>
  <div class="inner">
    <div class="row">
      <div class="dot" style="background:#E1F5EE;">🤝</div>
      <div class="rtext">
        <h4>Employee Assistance Programme (EAP)</h4>
        <p>Confidential counselling, legal & financial advice and practical life support.</p>
        <p class="how">0800 030 518 &nbsp;·&nbsp; healthassuredeap.co.uk</p>
      </div>
    </div>
    <div class="row">
      <div class="dot" style="background:#E6F1FB;">🧘</div>
      <div class="rtext">
        <h4>Wisdom App</h4>
        <p>Guided meditations, breathing, sleep support, mood tracking and 4-week wellbeing plans.</p>
        <p class="how">Download Wisdom app &nbsp;·&nbsp; log in with employer code</p>
      </div>
    </div>
    <div class="row">
      <div class="dot" style="background:#FAEEDA;">🏥</div>
      <div class="rtext">
        <h4>Occupational Health</h4>
        <p>Independent clinical assessment; fitness for work, adjustments and return-to-work advice.</p>
        <p class="how">Manager referral &nbsp;·&nbsp; employee consent always required</p>
      </div>
    </div>
    <div class="row">
      <div class="dot" style="background:#EEEDFE;">🏘️</div>
      <div class="rtext">
        <h4>Healthy Working Life — Bradford only</h4>
        <p>Local early-intervention health support for Bradford-based colleagues.</p>
        <p class="how">Online referral with employee consent</p>
      </div>
    </div>
  </div>
</div>

</body>
</html>
